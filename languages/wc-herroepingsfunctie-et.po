msgstr ""
"Nt. eritellimusel valmistatud pitseeritud hügieenitooted või kiiresti "
"riknevad kaubad – taganemisõiguseta tooted."

#: wc-herroepingsfunctie.php:1483
msgid "Uitgesloten product-ID's"
msgstr "Välistatud tooteidentifikaatorid"

#: wc-herroepingsfunctie.php:1487
msgid "Digitale producten uitsluiten"
msgstr "Välista digitaalsed tooted"

#: wc-herroepingsfunctie.php:1488
msgid "Virtuele/downloadbare producten niet tonen in de herroepingsfunctie"
msgstr ""
